# Force LF line endings on text files across all platforms.
# Prevents Windows checkouts from introducing CRLF that breaks tooling.

* text=auto eol=lf

# Binary files (no conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
